rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic RBAC: Only authenticated users can access
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // More specific rules can be added here, e.g.:
    // match /drones/{droneId} {
    //   allow read: if request.auth.token.role == 'AUTHORITY' || resource.data.ownerId == request.auth.uid;
    // }
  }
}
